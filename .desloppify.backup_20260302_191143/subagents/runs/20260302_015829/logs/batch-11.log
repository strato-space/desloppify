def coerce_target_score(value: object, *, fallback: float = 95.0) -> float:
    """Normalize target score-like values to a safe [0, 100] float."""
    fallback_value = float(fallback)

    if is_numeric(value):
        parsed = float(value)
    elif isinstance(value, str):
        text = value.strip()
        if not text:
            parsed = fallback_value
        else:
            try:
                parsed = float(text)
