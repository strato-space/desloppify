def cmd_deps(args, *, build_dep_graph, resolve_roslyn_cmd) -> None:
    """Show dependency info for a specific C# file or top coupled files."""
    graph = build_dep_graph(Path(args.path), roslyn_cmd=resolve_roslyn_cmd(args))

