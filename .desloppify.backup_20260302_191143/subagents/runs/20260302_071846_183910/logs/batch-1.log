def _print_resolve_summary(*, status: str, all_resolved: list[str]) -> None:
    verb = "Reopened" if status == "open" else "Resolved"
    print(colorize(f"\n{verb} {len(all_resolved)} finding(s) as {status}:", "green"))
    for fid in all_resolved[:20]:
