def _resolve_source_file(filepath: str, *, scan_root: Path | None) -> Path:
    if Path(filepath).is_absolute():
        return Path(filepath)
    if scan_root is not None:
        candidate = scan_root / filepath
        if candidate.exists():
            return candidate
    return Path(resolve_path(filepath))


