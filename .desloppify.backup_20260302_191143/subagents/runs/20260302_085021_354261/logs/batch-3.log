def _normalize_patterns(patterns: list[str]) -> list[str]:
    normalized: list[str] = []
    seen: set[str] = set()
    for raw in patterns:
        text = str(raw).strip()
        if not text or text in seen:
            continue
        seen.add(text)
        normalized.append(text)
