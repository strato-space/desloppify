import ast, pathlib
root=pathlib.Path('desloppify/app/commands/review')
mods={p.stem:p for p in root.glob('*.py')}
imports={m:set() for m in mods}
for m,p in mods.items():
    t=ast.parse(p.read_text())
    for n in ast.walk(t):
        if isinstance(n,ast.ImportFrom) and n.module is not None and n.level==1:
            base=n.module.split('.')[0]
            if base in mods: imports[m].add(base)
        if isinstance(n,ast.ImportFrom) and n.module is None and n.level==1:
            for a in n.names:
                base=a.name.split('.')[0]
                if base in mods: imports[m].add(base)

def cycles():
    seen=[]
    path=[]
    visiting=set(); visited=set(); out=[]
    def dfs(u):
        visiting.add(u); path.append(u)
        for v in imports[u]:
            if v in visiting:
                i=path.index(v); out.append(path[i:]+[v])
            elif v not in visited:
                dfs(v)
        path.pop(); visiting.remove(u); visited.add(u)
    for k in imports:
        if k not in visited: dfs(k)
    return out
print('cycles',cycles())
